msgstr "«%2$s» ішіндегі %1$s аргументі UTF-8 кодтауында болуы керек"

#: properties/import-export.c:239
#, c-format
msgid "argument of “%s” must be UTF-8 encoded"
msgstr "«%s» аргументі UTF-8 кодтауында болуы керек"

